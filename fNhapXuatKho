        private void btnLuu_Click(object sender, EventArgs e)
        {
            decimal sl = 0, gia = 0;
            decimal.TryParse(txtSL.Text, out sl);
            decimal.TryParse(txtDonGia.Text, out gia);
            decimal thanhTien = sl * gia;

            dataGridView1.Rows.Add(txtMaPhieu.Text, txtTenSP.Text, txtSL.Text, txtDonVi.Text, txtDonGia.Text, thanhTien, cboPhanLoai.Text);
            MessageBox.Show("Thêm thành công!");
        }

        // 3. Chỗ này dành cho nút SỬA (Nhấp đúp vào nút Sửa trên Design sẽ ra chỗ này)
        private void btnSua_Click(object sender, EventArgs e)
        {
            if (index >= 0)
            {
                decimal sl = 0, gia = 0;
                decimal.TryParse(txtSL.Text, out sl);
                decimal.TryParse(txtDonGia.Text, out gia);
                decimal thanhTien = sl * gia;

                dataGridView1.Rows[index].Cells[0].Value = txtMaPhieu.Text;
                dataGridView1.Rows[index].Cells[1].Value = txtTenSP.Text;
                dataGridView1.Rows[index].Cells[2].Value = txtSL.Text;
                dataGridView1.Rows[index].Cells[3].Value = txtDonVi.Text;
                dataGridView1.Rows[index].Cells[4].Value = txtDonGia.Text;
                dataGridView1.Rows[index].Cells[5].Value = thanhTien;
                dataGridView1.Rows[index].Cells[6].Value = cboPhanLoai.Text;
                MessageBox.Show("Sửa thành công!");
            }
        }

        // 4. Chỗ này dành cho nút XÓA (Nhấp đúp vào nút Xóa trên Design sẽ ra chỗ này)
        private void btnXoa_Click(object sender, EventArgs e)
        {
            if (index >= 0)
            {
                dataGridView1.Rows.RemoveAt(index);
                index = -1;
                MessageBox.Show("Xóa thành công!");
            }
        }

        // 5. Chỗ này dành cho CellClick (Nhấp đúp vào sự kiện CellClick trong bảng Properties - tia sét)
        private void dataGridView1_CellClick(object sender, DataGridViewCellEventArgs e)
        {
            index = e.RowIndex;
            if (index >= 0)
            {
                DataGridViewRow row = dataGridView1.Rows[index];
                // Gán ngược dữ liệu từ bảng lên các ô nhập liệu
                txtMaPhieu.Text = row.Cells[0].Value?.ToString();
                txtTenSP.Text = row.Cells[1].Value?.ToString();
                txtSL.Text = row.Cells[2].Value?.ToString();
                txtDonVi.Text = row.Cells[3].Value?.ToString();
                txtDonGia.Text = row.Cells[4].Value?.ToString();
                cboPhanLoai.Text = row.Cells[5].Value?.ToString();
            }
        }
